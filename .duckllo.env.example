# duckllo environment file.
#
# Copy this to .duckllo.env in the project root and fill in the blanks.
# Both `cmd/duckllo serve` and `cmd/runner` auto-load .duckllo.env (then
# .env as a fallback) from the current working directory at startup.
# Existing process env vars override the file, so CLI / Docker overrides
# always win.
#
# .duckllo.env is gitignored — never commit it.

# ─── Server (cmd/duckllo serve) ─────────────────────────────────────────

# Postgres connection string. Default below matches `docker compose up db`.
DATABASE_URL=postgres://duckllo:duckllo@localhost:5432/duckllo?sslmode=disable

# HTTP listen address.
DUCKLLO_ADDR=:3000

# Where multipart artifact uploads land on disk.
DUCKLLO_UPLOADS=uploads

# One-shot bootstrap of the gin steward account. Only honoured when no
# users exist yet; once gin is created the var is ignored.
# Comment this out after first launch.
DUCKLLO_GIN_PASSWORD=changeme

# Phase 2 only — read but unused in Phase 1.
# TAILSCALE_PREAUTH_KEY=tskey-auth-...
# CONTAINER_RUNTIME=docker

# ─── Runner (cmd/runner) ────────────────────────────────────────────────

# Where the runner posts state. Use the LAN IP of the duckllo server if
# the runner is on a different machine.
DUCKLLO_URL=http://localhost:3000

# Project UUID + API key. Mint these in the UI: Project → Settings →
# API Keys → Mint. The plaintext key is shown ONCE and only once.
DUCKLLO_PROJECT=
DUCKLLO_KEY=

# Filesystem path the executor agent edits. The runner creates this dir
# if it doesn't exist. Phase 2 will mount this into a per-spec container.
DUCKLLO_WORKSPACE=./workspace

# Stable identifier for this runner — used in logs and lock ownership.
# Default is hostname-pid; override if you run multiple on one box.
# DUCKLLO_RUNNER_ID=mac-mini-1

# Comma-separated phases the runner will claim. Drop phases here if you
# want one process to handle planning only and another to execute.
# DUCKLLO_ROLES=planner,executor,validator,corrector

# ─── Anthropic ──────────────────────────────────────────────────────────

# Required by the runner. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# Override the default model. Default is claude-sonnet-4-6.
# DUCKLLO_MODEL=claude-sonnet-4-6

# ─── Optional: chromedp / screenshot sensor ────────────────────────────

# Base URL the screenshot sensor hits when a criterion sensor_spec.url
# is relative or missing. Phase 2 will populate this from the per-spec
# tailnet node automatically.
# DUCKLLO_DEV_URL=http://localhost:8080

# Override the Chrome / Chromium binary path if chromedp can't find one.
# DUCKLLO_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
